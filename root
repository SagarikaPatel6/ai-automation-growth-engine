  .project-card-sm .project-title { font-size: 1.2rem; }
  .project-desc { font-size: 0.9rem; color: var(--muted); line-height: 1.7; margin-bottom: 1.25rem; }
  .project-impact { font-family: 'DM Serif Display', serif; font-style: italic; color: var(--accent); margin-bottom: 1.25rem; }
