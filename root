  /* SMALLER GRID BELOW */
  .projects-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.5px; background: var(--border); }

  /* SHARED CARD STYLES */
  .project-card { background: var(--card-bg); padding: 2.5rem; position: relative; overflow: hidden; transition: background 0.3s; text-decoration: none; color: inherit; display: block; }
  .project-card-sm { background: var(--card-bg); padding: 2rem; position: relative; overflow: hidden; transition: background 0.3s; text-decoration: none; color: inherit; display: block; }
