  .hero-wrap { max-width: 1100px; margin: 0 auto; position: relative; }
  .hero { min-height: 100vh; display: flex; flex-direction: column; justify-content: center; padding: 8rem 3rem 4rem; }
  .hero-eyebrow { font-family: 'DM Mono', monospace; font-size: 0.72rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--accent); margin-bottom: 1.5rem; opacity: 0; animation: fadeUp 0.7s 0.1s forwards; }
  .hero-name { font-family: 'DM Serif Display', serif; font-size: clamp(3.5rem, 8vw, 7rem); line-height: 1.0; letter-spacing: -0.03em; opacity: 0; animation: fadeUp 0.7s 0.25s forwards; }
  .hero-name em { font-style: italic; color: var(--accent); }
  .hero-title { font-family: 'DM Serif Display', serif; font-size: clamp(1.4rem, 3vw, 2.2rem); font-style: italic; color: var(--muted); margin-top: 0.5rem; opacity: 0; animation: fadeUp 0.7s 0.4s forwards; }
  .hero-desc { max-width: 540px; margin-top: 2rem; font-size: 1.05rem; opacity: 0; animation: fadeUp 0.7s 0.55s forwards; }
  .hero-desc strong { font-weight: 600; color: var(--accent2); }
  .hero-cta { display: flex; gap: 1rem; margin-top: 2.5rem; flex-wrap: wrap; opacity: 0; animation: fadeUp 0.7s 0.7s forwards; }

  .btn { display: inline-flex; align-items: center; gap: 0.4rem; padding: 0.75rem 1.75rem; font-family: 'DM Mono', monospace; font-size: 0.78rem; letter-spacing: 0.06em; text-transform: uppercase; text-decoration: none; border-radius: 2px; transition: all 0.2s; border: none; cursor: pointer; }
  .btn-primary { background: var(--ink); color: var(--paper); }
  .btn-primary:hover { background: var(--accent); transform: translateY(-2px); }
  .btn-outline { background: transparent; color: var(--ink); border: 1.5px solid var(--ink); }
  .btn-outline:hover { border-color: var(--accent); color: var(--accent); transform: translateY(-2px); }
  .btn-light { background: var(--paper); color: var(--ink); }
  .btn-light:hover { background: var(--accent); color: var(--paper); transform: translateY(-2px); }
  .btn-ghost { background: transparent; color: var(--paper); border: 1.5px solid rgba(245,242,235,0.3); }
  .btn-ghost:hover { border-color: var(--accent); color: var(--accent); transform: translateY(-2px); }

  .hero-deco { position: absolute; right: 2rem; top: 50%; transform: translateY(-50%); opacity: 0; animation: fadeIn 1.2s 0.9s forwards; }
  .deco-ring { width: 320px; height: 320px; border-radius: 50%; border: 1.5px solid var(--border); position: relative; display: flex; align-items: center; justify-content: center; }
  .deco-ring::before { content: ''; position: absolute; inset: 20px; border-radius: 50%; border: 1px dashed rgba(200,64,26,0.25); animation: spin 20s linear infinite; }
  .deco-ring::after { content: ''; position: absolute; inset: 60px; border-radius: 50%; background: radial-gradient(circle, rgba(200,64,26,0.07) 0%, transparent 70%); }
  .deco-center { font-family: 'DM Serif Display', serif; font-size: 5rem; opacity: 0.1; z-index: 1; }
  .deco-tags { position: absolute; font-family: 'DM Mono', monospace; font-size: 0.62rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); white-space: nowrap; }
  .deco-tags.t1 { top: 16%; right: -22%; }
  .deco-tags.t2 { bottom: 23%; left: -20%; }
  .deco-tags.t3 { top: 54%; right: -24%; }
  @keyframes spin { to { transform: rotate(360deg); } }

  .impact-bar { border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); padding: 3rem; display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; background: var(--card-bg); }
  .impact-item { text-align: center; }
  .impact-num { font-family: 'DM Serif Display', serif; font-size: 3.2rem; color: var(--accent); line-height: 1; letter-spacing: -0.03em; }
  .impact-label { font-family: 'DM Mono', monospace; font-size: 0.65rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--muted); margin-top: 0.5rem; }

  section { max-width: 1100px; margin: 0 auto; padding: 5rem 3rem; }
