  .detail-row { display: flex; gap: 1.5rem; padding: 1.1rem 0; border-bottom: 1px solid var(--border); }
  .detail-key { font-family: 'DM Mono', monospace; font-size: 0.65rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--muted); min-width: 80px; padding-top: 2px; flex-shrink: 0; }
