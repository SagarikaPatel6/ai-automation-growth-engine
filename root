  .tech-tags { display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .tech-tag { font-family: 'DM Mono', monospace; font-size: 0.62rem; letter-spacing: 0.08em; text-transform: uppercase; padding: 0.22rem 0.6rem; border: 1px solid var(--border); border-radius: 1px; color: var(--muted); }
  .project-arrow { position: absolute; top: 2rem; right: 2rem; font-size: 1.1rem; color: rgba(15,14,12,0.15); transition: all 0.3s; }
  .project-card:hover .project-arrow, .project-card-sm:hover .project-arrow { color: var(--accent); transform: translate(3px, -3px); }

  .stack-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 1px; background: var(--border); }
  .stack-item { background: var(--card-bg); padding: 2rem 2.5rem; }
  .stack-category { font-family: 'DM Mono', monospace; font-size: 0.63rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--accent); margin-bottom: 0.9rem; }
  .stack-title { font-family: 'DM Serif Display', serif; font-size: 1.1rem; margin-bottom: 0.75rem; color: var(--ink); }
